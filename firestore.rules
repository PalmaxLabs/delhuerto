rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir lectura pública de productos para el catálogo
    match /products/{product} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Perfiles de usuario (Productores/Consumidores)
    match /users/{userId} {
      allow read: if true; // Necesario para ver perfiles de productores
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Pedidos (Solo dueños y productores involucrados)
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
